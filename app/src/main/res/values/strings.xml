<resources>
    <string name="app_name">Tracker</string>

    <!-- Kept deliberately terse and neutral: the platform forces this notification to exist,
         so it says as little as possible rather than narrating each fix. -->
    <string name="notification_channel_name">Location service</string>
    <string name="notification_channel_description">Keeps location reporting running</string>
    <string name="notification_title">Location service active</string>
    <string name="notification_text_waiting">Running</string>

    <!-- Update-available notification, posted from the background service. Unlike the tracking
         notification this one is meant to be noticed. -->
    <string name="update_channel_name">App updates</string>
    <string name="update_channel_description">Notifies when a new version must be installed</string>
    <string name="update_notification_title">New version available</string>
    <string name="update_notification_text">A new version of Tracker is available. Tap to update.</string>
    <string name="update_notification_text_versioned">Tracker %1$s is available. Tap to update.</string>

    <!-- Connectivity warning, posted from the background service while the internet is down.
         Meant to be noticed, so it uses a DEFAULT-importance channel. -->
    <string name="offline_channel_name">Connectivity</string>
    <string name="offline_channel_description">Warns when the device loses internet access</string>
    <string name="offline_notification_title">Internet is off</string>
    <string name="offline_notification_text">No internet connection. Location fixes are being saved and will upload once you\'re back online.</string>
</resources>
